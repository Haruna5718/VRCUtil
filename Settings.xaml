<Page path="settings" icon="¯£ô" name="Settings" title="Settings" state="{vrcutil_hasUpdate}">
    <Box>
        <Horizontal>
            <Text>¯×É App theme</Text>
            <Space />
            <Select value="system_theme">
                <Option value="dark">¯£ê Dark</Option>
                <Option value="light">¯£å Light</Option>
                <Option value="system">¯óò Use system setting</Option>
            </Select>
        </Horizontal>
    </Box>
    <Box>
        <Horizontal gap="10px">
            <Text>¯╝╗ Auto start</Text>
            <Space />
            <Select value="settings_autoStart">
                <Option value="0">¯úÿ Disable Auto start</Option>
                <Option value="1">´äÖ Start with SteamVR</Option>
                <Option value="3">¯ƒ¿ Start with System</Option>
            </Select>
        </Horizontal>
    </Box>
    <Box>
        <Horizontal>
            <Text>¯Âó Use tray</Text>
            <Space />
            <Switch value="settings_useTray"/>
        </Horizontal>
    </Box>
    <Box>
        <Horizontal>
            <Text>¯ÑÜ OSC</Text>
            <Space />
            <Vertical gap="0" align="left">
                <Text type="description">Address</Text>
                <Input value="settings_osc_address" width="115px">Address</Input>
            </Vertical>
            <Vertical gap="0" align="left">
                <Text type="description">Send</Text>
                <Input value="settings_osc_send" width="115px" type="number" min="0" max="65535">Port</Input>
            </Vertical>
            <Vertical gap="0" align="left">
                <Text type="description">Receive</Text>
                <Input value="settings_osc_receive" width="115px" type="number" min="0" max="65535">Port</Input>
            </Vertical>
        </Horizontal>
    </Box>
    <Expender>
        <Header>
            <Horizontal>
                <Text>¯¬å Modules</Text>
                <Space />
                <Text type="description">{vrcutil_modules.length} Modules loaded</Text>
            </Horizontal>
        </Header>
        <Content padding="8px">
            <If data="{vrcutil_modules.length}">
                <True>
                    <Repeat data="{vrcutil_modules.length}">
                        <Box padding="8px">
                            <Horizontal>
                                <Vertical gap="0" align="left">
                                    <Horizontal gap="6px" align="center">
                                        <Text url="{Object.values(vrcutil_modules[{i}][4][0])[0]}" color="var(--TextFillColorPrimaryBrush)">{vrcutil_modules[{i}][1]} ¯óº</Text>
                                        <Text type="description">{vrcutil_modules[{i}][2]}</Text>
                                    </Horizontal>
                                    <Text type="description">{vrcutil_modules[{i}][3]}</Text>
                                </Vertical>
                                <Space />
                                <Button value="vrcutil_removeModule_{vrcutil_modules[{i}][0]}">Remove</Button>
                            </Horizontal>
                        </Box>
                    </Repeat>
                </True>
                <False>
                    <Text color="var(--TextFillColorDisabledBrush)">ThereÔÇÖs nothing hereÔÇª at least not yet.</Text>
                </False>
            </If>
        </Content>
    </Expender>
    <Box>
        <Horizontal>
            <Text>¯×ï Check update</Text>
            <Space />
            <Vertical gap="0" align="right">
                <Text type="description">Current:</Text>
                <Text type="description">Latest:</Text>
            </Vertical>
            <Vertical gap="0" align="left">
                <Text type="description">{vrcutil_version}</Text>
                <Text type="description">{vrcutil_latest}</Text>
            </Vertical>
            <Switch value="settings_checkUpdate"/>
        </Horizontal>
    </Box>
    <If data="{vrcutil_debug}">
        <True>
            <Box>
                <Horizontal>
                    <Text>¯»¿ Debug log</Text>
                    <Space />
                    <Button type="link" value="vrcutil_openLog">Open log</Button>
                </Horizontal>
            </Box>
        </True>
    </If>
    <Expender>
        <Header>
            <Horizontal>
                <Image source="{system_icon}" height="30px"/>
                <Vertical gap="0" align="left" margin="0 6px">
                    <Text>VRCUtil</Text>
